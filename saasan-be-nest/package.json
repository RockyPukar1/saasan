{
  "name": "saasan-be-nest",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:worker": "nest start --entryFile worker",
    "start:worker:dev": "nest start --watch --entryFile worker",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed:smart": "pnpm seed:location && pnpm seed:report && pnpm seed:politics && pnpm seed:poll && pnpm seed:event",
    "seed:fake-data": "nest start --entryFile common/seeders/seed-all",
    "reset:fake-data": "nest start --entryFile common/seeders/reset-fake-data",
    "seed:all-fake": "pnpm seed:fake-data",
    "reset:preserve-locations": "nest start --entryFile common/seeders/reset-preserve-locations",
    "seed:location": "nest start --entryFile common/seeders/location/seed-location",
    "seed:report": "nest start --entryFile common/seeders/report/seed-report",
    "seed:politics": "nest start --entryFile common/seeders/politics/seed-politics",
    "seed:poll": "nest start --entryFile common/seeders/poll/seed-poll",
    "seed:event": "nest start --entryFile common/seeders/event/seed-event"
  },
  "dependencies": {
    "@keyv/redis": "^5.1.6",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.3",
    "bcryptjs": "^3.0.3",
    "cache-manager": "^7.2.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "crypto": "^1.0.1",
    "express": "^5.2.1",
    "generate-password": "^1.7.1",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "keyv": "^5.6.0",
    "mongoose": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/generate-password": "^1.5.3",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
